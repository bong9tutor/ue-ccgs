# =============================================================================
# 줄바꿈 정책
# =============================================================================

# 기본: Git이 자동 판단
* text=auto

# Shell 스크립트는 반드시 LF — Windows에서 CRLF로 체크아웃되면
# bash가 "#!/bin/bash\r" shebang을 해석하지 못해 "No such file or directory"
# 에러를 내며 실행 실패함 (CCGS 훅이 대표적 피해 사례)
*.sh text eol=lf

# CCGS 훅 디렉터리 전체 보호 (확장자 없는 스크립트 포함)
.claude/hooks/** text eol=lf
.claude/statusline.sh text eol=lf

# Python도 플랫폼 간 일관성을 위해 LF 권장
*.py text eol=lf

# Windows 전용 파일은 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리 파일 명시 (LFS와 별개로 eol 변환 방지)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# =============================================================================
# 언리얼 엔진 에셋 (Git LFS)
# =============================================================================
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
